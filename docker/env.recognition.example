# 图片识别（复制到 docker/.env）
# yolo = 本地 OpenVINO（默认）| vision = 云端 Vision | auto = YOLO 失败再 Vision

RECOGNITION_PROVIDER=yolo
# Celery 经 WireGuard 访问本机 YOLO（本机 WG：192.168.100.19）
YOLO_API_URL=http://192.168.100.19:8765
YOLO_API_KEY=
YOLO_MODEL=yolo11
YOLO_CONF=0.25

# 云端 Vision 兜底（auto / vision 时使用）
AI_PROVIDER=custom
AI_API_KEY=
AI_BASE_URL=https://ai.shxybar.com
AI_VISION_MODEL=kimi-k2.5
