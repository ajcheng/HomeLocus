# Database
DATABASE_URL=postgresql+asyncpg://homelocus:homelocus@localhost:5432/homelocus
DATABASE_URL_SYNC=postgresql://homelocus:homelocus@localhost:5432/homelocus

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=homelocus
MINIO_SECURE=false

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=master-key

# AI (DeepSeek)
DEEPSEEK_API_KEY=your-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# JWT (CHANGE in production!)
JWT_SECRET=change-this-to-a-random-secret-in-production

# App
APP_ENV=development
STORAGE_BACKEND=minio
LOG_LEVEL=INFO

# Deployment
# For production, set APP_ENV=production and use strong JWT_SECRET
# Enable HTTPS via reverse proxy (nginx/Caddy)
# API base URL for presigned URL generation:
# PUBLIC_BASE_URL=https://your-domain.com
