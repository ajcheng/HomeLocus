# Database
DATABASE_URL=postgresql+asyncpg://homelocus:homelocus@localhost:5432/homelocus
DATABASE_URL_SYNC=postgresql://homelocus:homelocus@localhost:5432/homelocus

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage — "local" (default), "minio", or "s3"
STORAGE_BACKEND=local
# Local storage path (ignored when using minio/s3)
STORAGE_LOCAL_PATH=/data/HomeLocus/uploads
# S3/MinIO settings (only used when STORAGE_BACKEND=minio or s3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=homelocus
STORAGE_SECURE=false

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=master-key

# AI — "deepseek", "openai", or "custom"
AI_PROVIDER=deepseek
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# JWT (CHANGE in production!)
JWT_SECRET=change-this-to-a-random-secret-in-production

# App
APP_ENV=development
LOG_LEVEL=INFO
